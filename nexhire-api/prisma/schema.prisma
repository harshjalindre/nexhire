generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-Tenant Core ─────────────────────────────
model Tenant {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique @db.VarChar(10)
  logo      String?
  tier      String   @default("basic") @db.VarChar(20)
  status    String   @default("active") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users        User[]
  companies    Company[]
  drives       Drive[]
  students     Student[]
  subscription Subscription?
  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  email     String
  password  String
  role      String   @db.VarChar(20)
  avatar    String?
  status    String   @default("active") @db.VarChar(20)
  resetToken        String?   @map("reset_token")
  resetTokenExpiry  DateTime? @map("reset_token_expiry")
  emailVerified     Boolean   @default(false) @map("email_verified")
  verifyToken       String?   @map("verify_token")
  failedLogins      Int       @default(0) @map("failed_logins")
  lockedUntil       DateTime? @map("locked_until")
  refreshToken      String?   @map("refresh_token")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  student       Student?
  recruiter     Recruiter?
  notifications Notification[]
  auditLogs     AuditLog[]
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Recruiter {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  tenantId    String   @map("tenant_id")
  companyId   String?  @map("company_id")
  designation String?  @db.VarChar(100)
  phone       String?  @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id])
  company     Company? @relation(fields: [companyId], references: [id])
  drives      Drive[]
  @@index([tenantId])
  @@index([companyId])
  @@map("recruiters")
}

model Student {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  tenantId          String   @map("tenant_id")
  branch            String   @db.VarChar(100)
  year              Int
  cgpa              Float
  backlogs          Int      @default(0)
  skills            Json     @default("[]")
  resumeUrl         String?  @map("resume_url")
  placementStatus   String   @default("unplaced") @map("placement_status") @db.VarChar(20)
  profileCompletion Int      @default(0) @map("profile_completion")
  profileData       Json?    @map("profile_data")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user         User          @relation(fields: [userId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  applications Application[]
  @@index([tenantId])
  @@index([tenantId, branch])
  @@index([tenantId, placementStatus])
  @@map("students")
}

model Company {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  industry    String   @db.VarChar(100)
  website     String?
  logo        String?
  description String?  @db.Text
  contactName String   @map("contact_name")
  contactEmail String  @map("contact_email")
  contactPhone String? @map("contact_phone")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  drives     Drive[]
  recruiters Recruiter[]
  @@index([tenantId])
  @@map("companies")
}

model Drive {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  companyId   String   @map("company_id")
  createdById String?  @map("created_by_id")
  title       String
  description String   @db.Text
  branches    Json     @default("[]")
  minCgpa     Float    @map("min_cgpa")
  maxBacklogs Int      @map("max_backlogs")
  packageLpa  Float    @map("package_lpa")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  rounds      Json     @default("[]")
  status      String   @default("draft") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  company      Company       @relation(fields: [companyId], references: [id])
  createdBy    Recruiter?    @relation(fields: [createdById], references: [id])
  applications Application[]
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([createdById])
  @@map("drives")
}

model Application {
  id           String   @id @default(uuid())
  driveId      String   @map("drive_id")
  studentId    String   @map("student_id")
  status       String   @default("applied") @db.VarChar(20)
  roundStatuses Json    @default("[]") @map("round_statuses")
  appliedAt    DateTime @default(now()) @map("applied_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  drive   Drive   @relation(fields: [driveId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  @@unique([driveId, studentId])
  @@index([studentId])
  @@index([driveId, status])
  @@map("applications")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   @db.VarChar(30)
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id])
  @@index([userId, read])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(50)
  entityId  String?  @map("entity_id")
  meta      Json?
  ip        String?  @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model Subscription {
  id            String   @id @default(uuid())
  tenantId      String   @unique @map("tenant_id")
  planId        String   @map("plan_id") @db.VarChar(20)
  status        String   @default("active") @db.VarChar(20)
  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")
  cancelledAt   DateTime? @map("cancelled_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  invoices      Invoice[]
  @@map("subscriptions")
}

model Invoice {
  id              String   @id @default(uuid())
  subscriptionId  String   @map("subscription_id")
  amount          Float
  currency        String   @default("INR") @db.VarChar(3)
  status          String   @default("paid") @db.VarChar(20)
  paidAt          DateTime? @map("paid_at")
  invoiceNumber   String   @unique @map("invoice_number")
  createdAt       DateTime @default(now()) @map("created_at")
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  @@map("invoices")
}

model UsageLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  metric    String   @db.VarChar(50)
  count     Int      @default(0)
  month     String   @db.VarChar(7)
  updatedAt DateTime @updatedAt @map("updated_at")
  @@unique([tenantId, metric, month])
  @@map("usage_logs")
}